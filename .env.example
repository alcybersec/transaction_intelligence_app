# Database
POSTGRES_USER=txnuser
POSTGRES_PASSWORD=txnpass
POSTGRES_DB=txndb

# Security - CHANGE THESE IN PRODUCTION
SECRET_KEY=your-secret-key-change-in-production
ENCRYPTION_KEY=your-32-byte-encryption-key-here

# Proton Mail Bridge IMAP (runs on host)
IMAP_HOST=host.docker.internal
IMAP_PORT=1143
IMAP_USER=your-proton-email@protonmail.com
IMAP_PASSWORD=your-bridge-password

# Ollama (optional, for AI features)
OLLAMA_BASE_URL=http://192.168.1.100:11434
OLLAMA_MODEL=llama3

# Ingestion security (Tasker HMAC)
INGESTION_HMAC_SECRET=your-hmac-secret-for-tasker

# Ports (change if defaults conflict with existing services)
POSTGRES_PORT=5434
REDIS_PORT=6381
API_PORT=8001
FRONTEND_PORT=5174

# Frontend
VITE_API_URL=http://localhost:8001
